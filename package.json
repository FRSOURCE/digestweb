    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "feed": "^4.2.2",
    "globals": "^17.4.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
